[options]
addons_path = {% if use_docker %}/mnt/extra-addons{% else %}addons{% endif %}
admin_passwd = admin
data_dir = {% if use_docker %}/var/lib/odoo{% else %}.odoo-data{% endif %}
db_host = {% if use_docker %}db{% else %}localhost{% endif %}
db_port = 5432
db_user = odoo
db_password = odoo
http_port = 8069
log_level = info
